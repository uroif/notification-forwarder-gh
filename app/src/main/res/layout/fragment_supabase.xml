<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ios_background">
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/actionButtonsCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/ios_spacing_lg"
            android:paddingBottom="0dp">
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/ios_spacing_sm"
                android:background="@drawable/ios_card_background"
                android:elevation="@dimen/ios_card_elevation">
                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/enableSupabaseSwitch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="@dimen/ios_spacing_lg"
                    android:text="Enable Supabase Forwarding"
                    android:textAppearance="@style/TextAppearance.App.Body.iOS"
                    style="@style/Widget.App.Switch.iOS" />
            </androidx.cardview.widget.CardView>
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/ios_spacing_xl"
                android:background="@drawable/ios_card_background"
                android:elevation="@dimen/ios_card_elevation">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/ios_spacing_lg">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Supabase URL"
                        android:textAppearance="@style/TextAppearance.App.Headline.iOS"
                        android:textColor="@color/ios_label"
                        android:layout_marginBottom="@dimen/ios_spacing_sm" />
                    <EditText
                        android:id="@+id/supabaseUrlEditText"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/ios_text_field_height"
                        android:hint="https://xxxxx.supabase.co"
                        android:inputType="textUri"
                        android:background="@drawable/ios_text_field_background"
                        android:paddingStart="@dimen/ios_spacing_lg"
                        android:paddingEnd="@dimen/ios_spacing_lg"
                        android:textAppearance="@style/TextAppearance.App.Body.iOS"
                        android:textColor="@color/ios_label" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/ios_spacing_xl"
                android:background="@drawable/ios_card_background"
                android:elevation="@dimen/ios_card_elevation">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/ios_spacing_lg">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Supabase Anon Key"
                        android:textAppearance="@style/TextAppearance.App.Headline.iOS"
                        android:textColor="@color/ios_label"
                        android:layout_marginBottom="@dimen/ios_spacing_sm" />
                    <EditText
                        android:id="@+id/supabaseAnonKeyEditText"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/ios_text_field_height"
                        android:hint="eyJhbGciOiJIUzI1NiIsInR5cCI6..."
                        android:inputType="text"
                        android:background="@drawable/ios_text_field_background"
                        android:paddingStart="@dimen/ios_spacing_lg"
                        android:paddingEnd="@dimen/ios_spacing_lg"
                        android:textAppearance="@style/TextAppearance.App.Body.iOS"
                        android:textColor="@color/ios_label" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/ios_spacing_xl"
                android:background="@drawable/ios_card_background"
                android:elevation="@dimen/ios_card_elevation">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/ios_spacing_lg">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Device ID (Optional)"
                        android:textAppearance="@style/TextAppearance.App.Headline.iOS"
                        android:textColor="@color/ios_label"
                        android:layout_marginBottom="@dimen/ios_spacing_sm" />
                    <EditText
                        android:id="@+id/deviceIdEditText"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/ios_text_field_height"
                        android:hint="my-android-device"
                        android:inputType="text"
                        android:background="@drawable/ios_text_field_background"
                        android:paddingStart="@dimen/ios_spacing_lg"
                        android:paddingEnd="@dimen/ios_spacing_lg"
                        android:textAppearance="@style/TextAppearance.App.Body.iOS"
                        android:textColor="@color/ios_label" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/ios_spacing_xl"
                android:layout_marginBottom="@dimen/ios_spacing_xl"
                android:background="@drawable/ios_card_background"
                android:elevation="@dimen/ios_card_elevation">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/ios_spacing_lg">
                    <TextView
                        android:id="@+id/supabaseStatusTextView"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:text="Status: Not configured"
                        android:textAppearance="@style/TextAppearance.App.Body.iOS"
                        android:textColor="@color/ios_label_secondary" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </ScrollView>
    <LinearLayout
        android:id="@+id/actionButtonsCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="@dimen/ios_spacing_lg"
        android:background="@color/ios_background"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        <Button
            android:id="@+id/saveSupabaseButton"
            android:layout_width="0dp"
            android:layout_height="@dimen/ios_button_height"
            android:layout_weight="0.7"
            android:layout_marginEnd="@dimen/ios_spacing_sm"
            android:backgroundTint="@color/button_save_green"
            android:text="Save"
            android:textAllCaps="false"
            style="@style/Widget.App.Button.iOS" />
        <Button
            android:id="@+id/testSupabaseButton"
            android:layout_width="0dp"
            android:layout_height="@dimen/ios_button_height"
            android:layout_weight="1.3"
            android:layout_marginStart="@dimen/ios_spacing_sm"
            android:text="Test Connection"
            android:textAllCaps="false"
            style="@style/Widget.App.Button.iOS" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
