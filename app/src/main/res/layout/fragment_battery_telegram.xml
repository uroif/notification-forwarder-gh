<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ios_background">
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/actionButtonsLayout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/ios_spacing_lg"
            android:paddingBottom="0dp">
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/ios_spacing_lg"
                android:background="@drawable/ios_card_background"
                android:elevation="@dimen/ios_card_elevation">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="@dimen/ios_spacing_xl"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Send via Telegram"
                        android:textAppearance="@style/TextAppearance.App.Body.iOS"
                        android:textColor="@color/ios_label" />
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/enableBatteryTelegramSwitch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        style="@style/Widget.App.Switch.iOS" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/ios_spacing_lg"
                android:background="@drawable/ios_card_background"
                android:elevation="@dimen/ios_card_elevation">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/ios_spacing_xl">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bot Token"
                        android:textAppearance="@style/TextAppearance.App.Headline.iOS"
                        android:textColor="@color/ios_label"
                        android:layout_marginBottom="@dimen/ios_spacing_sm" />
                    <EditText
                        android:id="@+id/batteryBotTokenEditText"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/ios_text_field_height"
                        android:hint="@string/bot_token_hint"
                        android:inputType="text"
                        android:background="@drawable/ios_text_field_background"
                        android:paddingStart="@dimen/ios_spacing_md"
                        android:paddingEnd="@dimen/ios_spacing_md"
                        android:textAppearance="@style/TextAppearance.App.Body.iOS"
                        android:textColor="@color/ios_label" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/ios_spacing_xl"
                android:background="@drawable/ios_card_background"
                android:elevation="@dimen/ios_card_elevation">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/ios_spacing_xl">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Chat IDs (max 5)"
                        android:textAppearance="@style/TextAppearance.App.Headline.iOS"
                        android:textColor="@color/ios_label"
                        android:layout_marginBottom="@dimen/ios_spacing_md" />
                    <LinearLayout
                        android:id="@+id/batteryChatIdContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />
                    <Button
                        android:id="@+id/addBatteryChatIdButton"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/ios_button_height"
                        android:layout_marginTop="@dimen/ios_spacing_md"
                        android:text="+ Add Chat ID"
                        android:textAllCaps="false"
                        style="@style/Widget.App.Button.iOS" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </ScrollView>
    <LinearLayout
        android:id="@+id/actionButtonsLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="@dimen/ios_spacing_lg"
        android:background="@color/ios_background"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        <Button
            android:id="@+id/saveBatteryTelegramButton"
            android:layout_width="0dp"
            android:layout_height="@dimen/ios_button_height"
            android:layout_weight="1"
            android:layout_marginEnd="@dimen/ios_spacing_sm"
            android:backgroundTint="@color/button_save_green"
            android:text="Save"
            android:textAllCaps="false"
            style="@style/Widget.App.Button.iOS" />
        <Button
            android:id="@+id/testBatteryTelegramButton"
            android:layout_width="0dp"
            android:layout_height="@dimen/ios_button_height"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/ios_spacing_sm"
            android:text="Test Send"
            android:textAllCaps="false"
            style="@style/Widget.App.Button.iOS" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
