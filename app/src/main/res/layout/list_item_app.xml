<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="@dimen/ios_spacing_lg"
    android:layout_marginEnd="@dimen/ios_spacing_lg"
    android:layout_marginTop="@dimen/ios_spacing_xs"
    android:layout_marginBottom="@dimen/ios_spacing_xs"
    android:background="@drawable/ios_card_background"
    android:elevation="@dimen/ios_card_elevation">
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/ios_spacing_lg"
        android:minHeight="@dimen/ios_list_item_height">
        <ImageView
            android:id="@+id/appIconImageView"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:contentDescription="@null" />
        <TextView
            android:id="@+id/appNameTextView"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/appIconImageView"
            android:layout_toStartOf="@+id/appCheckBox"
            android:layout_centerVertical="true"
            android:layout_marginStart="@dimen/ios_spacing_lg"
            android:textAppearance="@style/TextAppearance.App.Body.iOS"
            android:textColor="@color/ios_label" />
        <CheckBox
            android:id="@+id/appCheckBox"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:buttonTint="@color/ios_blue" />
    </RelativeLayout>
</androidx.cardview.widget.CardView>
