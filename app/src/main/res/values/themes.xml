<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.NotificationForwarder" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/ios_blue</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/ios_blue</item>
        <item name="colorOnPrimaryContainer">@color/white</item>
        <item name="colorSecondary">@color/ios_green</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorError">@color/ios_red</item>
        <item name="colorOnError">@color/white</item>
        <item name="android:colorBackground">@color/ios_background</item>
        <item name="colorSurface">@color/ios_grouped_background_secondary</item>
        <item name="colorOnSurface">@color/ios_label</item>
        <item name="colorSurfaceVariant">@color/ios_gray6</item>
        <item name="android:textColorPrimary">@color/ios_label</item>
        <item name="android:textColorSecondary">@color/ios_label_secondary</item>
        <item name="android:textColorTertiary">@color/ios_label_tertiary</item>
        <item name="android:statusBarColor">@color/ios_background</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:navigationBarColor">@color/ios_background</item>
        <item name="android:windowLightNavigationBar">true</item>
    </style>
    <style name="Theme.NotificationForwarder" parent="Base.Theme.NotificationForwarder" />
    <style name="Widget.App.Button.iOS" parent="Widget.Material3.Button">
        <item name="android:textSize">@dimen/ios_body</item>
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">@dimen/ios_corner_radius_md</item>
        <item name="android:minHeight">@dimen/ios_button_height</item>
        <item name="android:paddingStart">@dimen/ios_spacing_lg</item>
        <item name="android:paddingEnd">@dimen/ios_spacing_lg</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
    <style name="Widget.App.CardView.iOS" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">@dimen/ios_corner_radius_md</item>
        <item name="cardElevation">@dimen/ios_card_elevation</item>
        <item name="cardBackgroundColor">@color/ios_grouped_background_secondary</item>
        <item name="contentPadding">@dimen/ios_spacing_lg</item>
    </style>
    <style name="Widget.App.Switch.iOS" parent="Widget.Material3.CompoundButton.MaterialSwitch">
        <item name="thumbTint">@color/switch_thumb_color</item>
        <item name="trackTint">@color/switch_track_color</item>
    </style>
    <style name="Widget.App.TabLayout.iOS" parent="Widget.Material3.TabLayout">
        <item name="tabIndicatorColor">@color/ios_blue</item>
        <item name="tabIndicatorHeight">2dp</item>
        <item name="tabSelectedTextColor">@color/ios_blue</item>
        <item name="tabTextColor">@color/ios_gray</item>
        <item name="tabIndicatorFullWidth">false</item>
        <item name="android:background">@color/ios_grouped_background_secondary</item>
        <item name="tabTextAppearance">@style/TextAppearance.App.Tab.iOS</item>
    </style>
    <style name="TextAppearance.App.LargeTitle.iOS" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:textSize">@dimen/ios_large_title</item>
        <item name="android:textColor">@color/ios_label</item>
        <item name="android:fontFamily">sans-serif-black</item>
    </style>
    <style name="TextAppearance.App.Title.iOS" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textSize">@dimen/ios_title</item>
        <item name="android:textColor">@color/ios_label</item>
        <item name="android:fontFamily">sans-serif-black</item>
    </style>
    <style name="TextAppearance.App.Headline.iOS" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textSize">@dimen/ios_headline</item>
        <item name="android:textColor">@color/ios_label</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
    <style name="TextAppearance.App.Body.iOS" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textSize">@dimen/ios_body</item>
        <item name="android:textColor">@color/ios_label</item>
    </style>
    <style name="TextAppearance.App.Caption.iOS" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textSize">@dimen/ios_caption</item>
        <item name="android:textColor">@color/ios_label_secondary</item>
    </style>
    <style name="TextAppearance.App.Tab.iOS" parent="TextAppearance.Material3.TitleSmall">
        <item name="android:textSize">@dimen/ios_callout</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="textAllCaps">false</item>
    </style>
</resources>
